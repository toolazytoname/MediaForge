<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  M3-2 launchd plist — 每日 state.db 备份（HARD_PARTS §9）
  ARCHITECTURE §2 + HARD_PARTS §9: SQLite 单文件是唯一真相源，备份保留 14 天
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mediaforge.backup-db</string>
    <key>ProgramArguments</key>
    <array>
        <string>__PROJECT_ROOT__/scripts/backup_db.sh</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__PROJECT_ROOT__</string>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>__PROJECT_ROOT__/logs/launchd.backup-db.out.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_ROOT__/logs/launchd.backup-db.err.log</string>
</dict>
</plist>